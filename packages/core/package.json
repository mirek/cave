{
  "name": "@cavelang/core",
  "version": "0.1.0",
  "type": "module",
  "description": "CAVE domain model — claims, values, units, uncertainty, claim keys, UUIDv7 transactions.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
