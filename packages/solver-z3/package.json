{
  "name": "@cavelang/solver-z3",
  "version": "0.28.0",
  "type": "module",
  "description": "Optional Node.js Z3 WebAssembly adapter and allowlisted workflow fixture for CAVE formal reasoning.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/solver-z3"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "cave-solver-workflow": "./src/workflow-main.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "scripts",
    "README.md",
    "BENCHMARK.md",
    "License.md",
    "Authors.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "bin": {
      "cave-solver-workflow": "./dist/src/workflow-main.js"
    }
  },
  "scripts": {
    "benchmark": "node --disable-warning=ExperimentalWarning scripts/benchmark.ts",
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test \"test/*.test.ts\"",
    "typecheck": "tsc -b",
    "prepack": "node ../../scripts/prepare-package-legal.mjs && pnpm run build"
  },
  "dependencies": {
    "@cavelang/solver": "workspace:*",
    "z3-solver": "4.16.0"
  }
}
