{
  "name": "@cavelang/eval",
  "version": "0.15.0",
  "type": "module",
  "description": "CAVE evals harness (roadmap item 9) — golden-fixture extraction and query evals: plain-file suites, N runs against any agent, claim-key scoring with value tolerance, optional LLM judge.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/eval"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/ingest": "workspace:*",
    "@cavelang/loop": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
