{
  "name": "@cavelang/connect",
  "version": "0.27.14",
  "type": "module",
  "description": "Deterministic structured ingestion (spec §23) — CSV/TSV/JSON/JSONL/SQLite/URL records mapped through CAVE templates with ?field variables into claims, with per-record digest incrementality, watch mode, and query-time overlay.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/connect"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
