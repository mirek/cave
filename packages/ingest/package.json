{
  "name": "@cavelang/ingest",
  "version": "0.28.0",
  "type": "module",
  "description": "LLM-driven knowledge ingestion — batch files and web pages (fetch + Readability) through any headless agent (claude, copilot, custom SDK scripts) into a CAVE database.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/ingest"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/mcp": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/store": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12"
  }
}
