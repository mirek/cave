{
  "name": "@cavelang/canonical",
  "version": "0.29.1",
  "type": "module",
  "description": "CAVE canonicalization — verb lifecycle and inverse registry, continuation expansion, canonical emitter.",
  "keywords": [
    "cave",
    "knowledge-graph",
    "knowledge-representation",
    "typescript"
  ],
  "homepage": "https://github.com/mirek/cave#readme",
  "bugs": {
    "url": "https://github.com/mirek/cave/issues"
  },
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/canonical"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md",
    "Authors.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test \"test/*.test.ts\"",
    "typecheck": "tsc -b",
    "prepack": "node ../../scripts/prepare-package-legal.mjs && pnpm run build"
  },
  "dependencies": {
    "@cavelang/core": "workspace:*",
    "@cavelang/parser": "workspace:*"
  }
}
