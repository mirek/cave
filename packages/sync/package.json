{
  "name": "@cavelang/sync",
  "version": "0.27.1",
  "type": "module",
  "description": "CAVE store merge (spec §28) — merge append-only stores by row identity: idempotent, transitive, conflict-free by construction; SYNCED-INTO merge records, the tx receive rule, and `;@` transaction-annotated text interchange.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/sync"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
