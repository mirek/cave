{
  "name": "@cavelang/view",
  "version": "0.27.13",
  "type": "module",
  "description": "CAVE human read surface (spec §30, §31) — cave serve: one static, self-contained HTML page over the store (entity 360, topic browse, belief-history timeline, BECAUSE-edge lineage, coverage/frontier dashboard); cave report: templated markdown from CAVE-Q results with claim keys as citations.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/view"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/shape": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
