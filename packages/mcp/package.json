{
  "name": "@cave/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CAVE engine as an MCP server — stdio JSON-RPC exposing add/query/search/reconstruct tools over a knowledge database.",
  "exports": {
    ".": "./src/index.ts",
    "./bin": "./src/bin.ts"
  },
  "scripts": {
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cave/canonical": "workspace:*",
    "@cave/core": "workspace:*",
    "@cave/loop": "workspace:*",
    "@cave/query": "workspace:*",
    "@cave/store": "workspace:*",
    "@cave/parser": "workspace:*"
  }
}
