{
  "name": "@cavelang/act",
  "version": "0.27.9",
  "type": "module",
  "description": "CAVE action templates (spec §25) — named, parameterized governed writes: in-band declarations, CAVE-Q preconditions validated against current belief, atomic templated appends with BECAUSE/VIA lineage, and out-of-band side-effect hooks.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/act"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/connect": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/rules": "workspace:*",
    "@cavelang/shape": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
