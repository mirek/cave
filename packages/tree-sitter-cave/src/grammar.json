{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "cave",
  "rules": {
    "document": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_line"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "\\r?\\n"
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_line"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment_line"
        },
        {
          "type": "SYMBOL",
          "name": "qualifier_line"
        },
        {
          "type": "SYMBOL",
          "name": "claim_line"
        },
        {
          "type": "SYMBOL",
          "name": "continuation_line"
        }
      ]
    },
    "comment_line": {
      "type": "SYMBOL",
      "name": "comment"
    },
    "claim_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "subject",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_term"
              },
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "verb"
                },
                "named": true,
                "value": "entity"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_body"
        }
      ]
    },
    "continuation_line": {
      "type": "PREC_DYNAMIC",
      "value": -1,
      "content": {
        "type": "SYMBOL",
        "name": "_body"
      }
    },
    "_body": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC_RIGHT",
          "value": 0,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "FIELD",
                "name": "verb",
                "content": {
                  "type": "SYMBOL",
                  "name": "verb"
                }
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "negation"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              },
              {
                "type": "FIELD",
                "name": "payload",
                "content": {
                  "type": "SYMBOL",
                  "name": "_payload"
                }
              },
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "_meta"
                }
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "comment"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              }
            ]
          }
        },
        {
          "type": "PREC_RIGHT",
          "value": 0,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "FIELD",
                "name": "verb",
                "content": {
                  "type": "ALIAS",
                  "content": {
                    "type": "STRING",
                    "value": "EXISTS"
                  },
                  "named": true,
                  "value": "verb"
                }
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "negation"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              },
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "_meta"
                }
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "comment"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "qualifier_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "verb",
          "content": {
            "type": "SYMBOL",
            "name": "qualifier_verb"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "negation"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "payload",
          "content": {
            "type": "SYMBOL",
            "name": "_qualifier_payload"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_meta"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "qualifier_verb": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "WHEN"
        },
        {
          "type": "STRING",
          "value": "UNLESS"
        },
        {
          "type": "STRING",
          "value": "VIA"
        },
        {
          "type": "STRING",
          "value": "BECAUSE"
        }
      ]
    },
    "negation": {
      "type": "STRING",
      "value": "NOT"
    },
    "_payload": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attr_value"
        },
        {
          "type": "SYMBOL",
          "name": "value"
        },
        {
          "type": "SYMBOL",
          "name": "object"
        }
      ]
    },
    "attr_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "attribute",
          "content": {
            "type": "SYMBOL",
            "name": "attribute"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "value"
              },
              {
                "type": "SYMBOL",
                "name": "_term"
              }
            ]
          }
        }
      ]
    },
    "value": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "number"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "entity"
                },
                "named": true,
                "value": "unit"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "->"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "number"
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "ALIAS",
                        "content": {
                          "type": "SYMBOL",
                          "name": "entity"
                        },
                        "named": true,
                        "value": "unit"
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "object": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "code"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "entity"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "entity"
                  },
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "SYMBOL",
                      "name": "verb"
                    },
                    "named": true,
                    "value": "entity"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "verb"
          },
          "named": true,
          "value": "entity"
        }
      ]
    },
    "_qualifier_payload": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comparison"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "subject",
              "content": {
                "type": "SYMBOL",
                "name": "_term"
              }
            },
            {
              "type": "SYMBOL",
              "name": "_body"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_term"
        }
      ]
    },
    "comparison": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "left",
          "content": {
            "type": "SYMBOL",
            "name": "_term"
          }
        },
        {
          "type": "FIELD",
          "name": "operator",
          "content": {
            "type": "SYMBOL",
            "name": "comparison_op"
          }
        },
        {
          "type": "FIELD",
          "name": "right",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "value"
              },
              {
                "type": "SYMBOL",
                "name": "_term"
              }
            ]
          }
        }
      ]
    },
    "comparison_op": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "STRING",
          "value": ">="
        },
        {
          "type": "STRING",
          "value": "<="
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "!="
        }
      ]
    },
    "_term": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "entity"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "code"
        }
      ]
    },
    "_meta": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "context"
        },
        {
          "type": "SYMBOL",
          "name": "confidence"
        },
        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "uncertainty"
        },
        {
          "type": "SYMBOL",
          "name": "sigma"
        },
        {
          "type": "SYMBOL",
          "name": "importance"
        }
      ]
    },
    "uncertainty": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "+/-"
        },
        {
          "type": "SYMBOL",
          "name": "value"
        }
      ]
    },
    "tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "[^ \\t\\r\\n;:]+"
              }
            },
            "named": true,
            "value": "tag_key"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "IMMEDIATE_TOKEN",
                  "content": {
                    "type": "STRING",
                    "value": ":"
                  }
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "ALIAS",
                    "content": {
                      "type": "IMMEDIATE_TOKEN",
                      "content": {
                        "type": "PATTERN",
                        "value": "[^ \\t\\r\\n;]+"
                      }
                    },
                    "named": true,
                    "value": "tag_value"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "verb": {
      "type": "PATTERN",
      "value": "[A-Z][A-Z-]*"
    },
    "entity": {
      "type": "PATTERN",
      "value": "[\\p{L}_][\\p{L}\\p{M}\\p{N}_./-]*",
      "flags": "u"
    },
    "attribute": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[\\p{L}_][\\p{L}\\p{M}\\p{N}_./-]*:",
        "flags": "u"
      }
    },
    "number": {
      "type": "PATTERN",
      "value": "~?-?[0-9][0-9A-Za-z.,%_-]*"
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"\\r\\n]*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "code": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "`"
          },
          {
            "type": "PATTERN",
            "value": "[^`\\r\\n]*"
          },
          {
            "type": "STRING",
            "value": "`"
          }
        ]
      }
    },
    "context": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "@[^ \\t\\r\\n;]+"
      }
    },
    "confidence": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "@[ \\t]+[0-9]+(\\.[0-9]+)?%"
      }
    },
    "sigma": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\([0-9]+(\\.[0-9]+)?σ\\)"
      }
    },
    "importance": {
      "type": "STRING",
      "value": "!"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": ";[^\\r\\n]*"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}