{
  "name": "@cavelang/store",
  "version": "0.28.1",
  "type": "module",
  "description": "CAVE SQLite persistence — explicit runtime adapters, append-only belief series, and lifecycle-aware reads.",
  "keywords": ["cave", "knowledge-graph", "knowledge-representation", "typescript"],
  "homepage": "https://github.com/mirek/cave#readme",
  "bugs": { "url": "https://github.com/mirek/cave/issues" },
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/store"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": "./src/index.ts",
    "./adapter": "./src/adapter-entry.ts",
    "./adapter/node": "./src/node-adapter-entry.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md",
    "Authors.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "./adapter": {
        "types": "./dist/src/adapter-entry.d.ts",
        "default": "./dist/src/adapter-entry.js"
      },
      "./adapter/node": {
        "types": "./dist/src/node-adapter-entry.d.ts",
        "default": "./dist/src/node-adapter-entry.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test \"test/*.test.ts\"",
    "typecheck": "tsc -b",
    "prepack": "node ../../scripts/prepare-package-legal.mjs && pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*"
  }
}
