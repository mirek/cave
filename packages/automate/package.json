{
  "name": "@cavelang/automate",
  "version": "0.29.1",
  "private": true,
  "type": "module",
  "description": "CAVE automations (spec §29) — the event-driven loop: in-band trigger patterns over new claims fire rules, actions, out-of-band hooks and agent prompts; cave automate settles the store whenever belief changes.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/automate"
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0 || ^26.0.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --disable-warning=ExperimentalWarning --test \"test/*.test.ts\"",
    "typecheck": "tsc -b",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@cavelang/act": "workspace:*",
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/loop": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/rules": "workspace:*",
    "@cavelang/store": "workspace:*"
  }
}
