{
  "name": "@cavelang/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "cave — CLI for parsing, storing, querying and exporting CAVE knowledge.",
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "cave": "./src/main.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./main": "./src/main.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --disable-warning=ExperimentalWarning --test 'test/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/loop": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/store": "workspace:*",
    "@cavelang/mcp": "workspace:*",
    "@cavelang/ingest": "workspace:*"
  }
}
