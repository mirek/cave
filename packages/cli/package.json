{
  "name": "@cavelang/cli",
  "version": "0.29.0",
  "type": "module",
  "description": "cave — CLI for parsing, storing, querying and exporting CAVE knowledge.",
  "keywords": [
    "cave",
    "knowledge-graph",
    "knowledge-representation",
    "typescript"
  ],
  "homepage": "https://github.com/mirek/cave#readme",
  "bugs": {
    "url": "https://github.com/mirek/cave/issues"
  },
  "license": "CC0-1.0",
  "author": "Mirek Rusin (https://github.com/mirek)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "cave": "./src/main.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./main": "./src/main.ts",
    "./act": "./src/act.ts",
    "./automate": "./src/automate.ts",
    "./connect": "./src/connect.ts",
    "./eval": "./src/eval.ts",
    "./ingest": "./src/ingest.ts",
    "./loop": "./src/loop.ts",
    "./mcp": "./src/mcp.ts",
    "./rules": "./src/rules.ts",
    "./shape": "./src/shape.ts",
    "./sync": "./src/sync.ts",
    "./view": "./src/view.ts"
  },
  "files": [
    "dist",
    "!dist/test",
    "!dist/tsconfig.tsbuildinfo",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "License.md",
    "Authors.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "./main": {
        "types": "./dist/src/main.d.ts",
        "default": "./dist/src/main.js"
      },
      "./act": {
        "types": "./dist/internal/act/index.d.ts",
        "default": "./dist/internal/act/index.js"
      },
      "./automate": {
        "types": "./dist/internal/automate/index.d.ts",
        "default": "./dist/internal/automate/index.js"
      },
      "./connect": {
        "types": "./dist/internal/connect/index.d.ts",
        "default": "./dist/internal/connect/index.js"
      },
      "./eval": {
        "types": "./dist/internal/eval/index.d.ts",
        "default": "./dist/internal/eval/index.js"
      },
      "./ingest": {
        "types": "./dist/internal/ingest/index.d.ts",
        "default": "./dist/internal/ingest/index.js"
      },
      "./loop": {
        "types": "./dist/internal/loop/index.d.ts",
        "default": "./dist/internal/loop/index.js"
      },
      "./mcp": {
        "types": "./dist/internal/mcp/index.d.ts",
        "default": "./dist/internal/mcp/index.js"
      },
      "./rules": {
        "types": "./dist/internal/rules/index.d.ts",
        "default": "./dist/internal/rules/index.js"
      },
      "./shape": {
        "types": "./dist/internal/shape/index.d.ts",
        "default": "./dist/internal/shape/index.js"
      },
      "./sync": {
        "types": "./dist/internal/sync/index.d.ts",
        "default": "./dist/internal/sync/index.js"
      },
      "./view": {
        "types": "./dist/internal/view/index.d.ts",
        "default": "./dist/internal/view/index.js"
      }
    },
    "bin": {
      "cave": "./dist/src/main.js"
    }
  },
  "scripts": {
    "build": "tsc -b && node scripts/consolidate.mjs",
    "test": "node --disable-warning=ExperimentalWarning --test \"test/*.test.ts\"",
    "typecheck": "tsc -b",
    "prepack": "node ../../scripts/prepare-package-legal.mjs && pnpm run build"
  },
  "dependencies": {
    "@cavelang/canonical": "workspace:*",
    "@cavelang/core": "workspace:*",
    "@cavelang/fusion": "workspace:*",
    "@cavelang/highlight": "workspace:*",
    "@cavelang/parser": "workspace:*",
    "@cavelang/query": "workspace:*",
    "@cavelang/store": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@cavelang/act": "workspace:*",
    "@cavelang/automate": "workspace:*",
    "@cavelang/connect": "workspace:*",
    "@cavelang/eval": "workspace:*",
    "@cavelang/ingest": "workspace:*",
    "@cavelang/loop": "workspace:*",
    "@cavelang/mcp": "workspace:*",
    "@cavelang/rules": "workspace:*",
    "@cavelang/shape": "workspace:*",
    "@cavelang/sync": "workspace:*",
    "@cavelang/view": "workspace:*"
  }
}
