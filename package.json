{
  "name": "cave",
  "version": "0.27.14",
  "private": true,
  "type": "module",
  "description": "CAVE — Compressed Atomic Verb Expressions. Monorepo implementing the CAVE specification (see README.md).",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsc -b",
    "site:dev": "pnpm --filter @cavelang/website dev",
    "site:build": "pnpm --filter @cavelang/website build",
    "watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "rm -rf packages/*/dist",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "tsc -b",
    "version-packages": "changeset version && node scripts/sync-versions.mjs && pnpm install --lockfile-only --no-frozen-lockfile",
    "release:publish": "./scripts/release-publish.sh"
  },
  "devDependencies": {
    "@cavelang/cli": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
