{
  "name": "cave",
  "version": "0.22.0",
  "private": true,
  "type": "module",
  "description": "CAVE — Compressed Atomic Verb Expressions. Monorepo implementing the CAVE specification (see README.md).",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "rm -rf packages/*/dist",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@cavelang/cli": "workspace:*",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
