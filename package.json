{
  "name": "cave",
  "version": "0.29.1",
  "private": true,
  "type": "module",
  "description": "CAVE — Compressed Atomic Verb Expressions. Monorepo implementing the CAVE specification (see README.md).",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirek/cave.git"
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsc -b",
    "build:verify": "node scripts/verify-incremental-build.mjs",
    "bench:performance": "node --disable-warning=ExperimentalWarning scripts/performance-bench.mjs",
    "grammar:prepare": "node scripts/grammar-toolchain.mjs prepare",
    "grammar:verify": "node scripts/grammar-toolchain.mjs verify",
    "site:dev": "pnpm --filter @cavelang/website dev",
    "site:build": "pnpm --filter @cavelang/website build",
    "watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "node scripts/clean.mjs",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm run build",
    "version-packages": "changeset version && node scripts/sync-versions.mjs && pnpm install --lockfile-only --no-frozen-lockfile",
    "release:validate": "node scripts/release-validate.mjs --mode=publish",
    "release:validate:version-pr": "node scripts/release-validate.mjs --mode=version-pr",
    "release:publish": "./scripts/release-publish.sh"
  },
  "devDependencies": {
    "@cavelang/cli": "workspace:*",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^22.20.1",
    "typescript": "^5.8.0"
  }
}
